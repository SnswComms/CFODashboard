# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*
!.env.example

# Credentials / OAuth / local auth
*token*.json
*oauth*.json
*device_flow*.json
*client_secret*.json
*.pem
*.key
*.p12
*.pfx
# Mongo mutual-TLS client cert + CA (fetched from the VPS /etc/mongodb/ssl)
backend/certs/

# Generated dashboard outputs and private data
briefings/
dashboards/
output/
exports/
data/
cache/
*.log
*.sqlite
*.sqlite3
*.db
*.json
!examples/*.json
!schemas/*.json
# App source JSON (manifests, configs, synthetic fixtures) — the blanket
# *.json above guards private data exports, not code. node_modules/, .next/
# and data/ stay excluded (directory ignores can't be re-included).
!backend/**/*.json
!frontend/**/*.json
!.claude/launch.json

# Finance source files — never commit live operating data
*.xlsx
*.xlsm
*.xls
*.csv
*.pdf
*.docx

# OS/editor
.DS_Store
.idea/
.vscode/

# Node / Next.js
node_modules/
.next/
out/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
