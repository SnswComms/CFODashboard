PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# VPS hosting the self-hosted MongoDB (used by scripts/db-tunnel.py).
VPS_USER=root
VPS_IP=
VPS_PASSWORD=

# MongoDB connection. The VPS binds Mongo to 127.0.0.1 only, so for local dev
# run the SSH tunnel first (npm run db:tunnel) and point the URI at localhost.
# On the VPS itself, localhost works directly.
MONGODB_URI=mongodb://<user>:<password>@127.0.0.1:27017/cfodashboard?authSource=cfodashboard
MONGODB_DB=cfodashboard

# Root of the local CFO workspace (Hermes-CFO equivalent). When unset, the API
# serves synthetic fixtures from backend/fixtures.
#CFO_DATA_DIR=

# Optional per-directory overrides (default to subdirectories of CFO_DATA_DIR).
#DASHBOARDS_DIR=
#MYOB_CACHE_DIR=
#PAYROLL_DIR=
#REPORT_PACKS_DIR=
#SYNTHETIC_DIR=

# Live allowance email sending stays off unless explicitly enabled.
#SNSW_ALLOWANCE_EMAIL_LIVE_SEND=

# Better Auth (sessions, admin-managed users). Generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
APP_ORIGIN=http://localhost:3000

# Outbound mail (Gmail SMTP app password). EMAIL_DRY_RUN=1 logs instead of sending.
GOOGLE_USER=
GOOGLE_APP_PASS=
EMAIL_FROM="CFO Dashboard <you@example.com>"
#EMAIL_DRY_RUN=

# MYOB Advanced API (basic auth against the MYOB Advanced instance).
MYOB_URL=https://adventist.myobadvanced.com
MYOB_USERNAME=
MYOB_PASSWORD=
MYOB_COMPANY=Church
MYOB_COMPANY_TEST=Test
MYOB_BRANCH=SNC

# --- MYOB read-only sync (POST /api/myob/sync) ---
# Output dirs for the sync caches (created at sync time).
MYOB_CACHE_DIR=
DASHBOARDS_DIR=
# Contract endpoint family for entity GETs.
MYOB_ENDPOINT_FAMILY=Default/23.200.001
# Sync window start (YYYY-MM-DD); default is the previous July 1.
#MYOB_SYNC_FROM_DATE=
# CMF cash target account(s), comma separated.
#MYOB_CMF_TARGET_ACCOUNTS=111300
# Journal pull safety cap and request timeout.
#MYOB_SYNC_JOURNAL_LIMIT=200000
#MYOB_TIMEOUT_MS=120000
# In-process refresh cadence (hours); 0 disables the scheduler.
#MYOB_SYNC_INTERVAL_HOURS=6

# --- Decision copilot LLM (POST /api/command-centre/copilot) ---
# Local Qwen served by vLLM on morpheus over Tailscale (OpenAI-compatible, no
# auth). On any failure or timeout the copilot falls back to its deterministic
# grounded answers. Set COPILOT_LLM_DISABLED=1 to skip the LLM entirely.
#COPILOT_LLM_URL=http://100.87.6.30:8000/v1
#COPILOT_LLM_MODEL=qwen3.6-27b-awq
#COPILOT_LLM_TIMEOUT_MS=45000
#COPILOT_LLM_MAX_TOKENS=2000
#COPILOT_LLM_DISABLED=
